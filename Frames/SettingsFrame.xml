<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <Frame name="GLV_Settings" parent="UIParent" hidden="true" movable="true" resizable="false" toplevel="true" frameStrata="DIALOG" enableMouse="true">
        <Size>
            <AbsDimension x="900" y="670"/>
        </Size>
        <Anchors>
            <Anchor point="CENTER"/>
        </Anchors>

        <Backdrop bgFile="Interface\DialogFrame\UI-DialogBox-Background" edgeFile="Interface\DialogFrame\UI-DialogBox-Border" tile="true">
            <EdgeSize>
                <AbsValue val="16"/>
            </EdgeSize>
            <TileSize>
                <AbsValue val="32"/>
            </TileSize>
            <BackgroundInsets>
                <AbsInset left="5" right="5" top="5" bottom="5"/>
            </BackgroundInsets>
        </Backdrop>

        <Scripts>
            <OnLoad>
                this:RegisterForDrag("LeftButton");
                tinsert(UISpecialFrames, "GLV_Settings");
            </OnLoad>
            <OnShow>
                GLV_ResetDisplaySettingsChanged();
            </OnShow>
            <OnHide>
                GLV_CheckReloadOnClose();
            </OnHide>
            <OnDragStart>
                this:StartMoving();
            </OnDragStart>
            <OnDragStop>
                this:StopMovingOrSizing();
            </OnDragStop>
        </Scripts> 

        <Frames>

            <!-- HEADER -->
            <Frame name="$parentHeader" inherits="UIPanelFrameTemplate">
                <Size>
                    <AbsDimension x="900" y="60"/>
                </Size>
                <Anchors>
                    <Anchor point="TOPLEFT" RelativeTo="$parent" RelativePoint="TOPLEFT">
                        <Offset x="0" y="0"/>
                    </Anchor>
                </Anchors>

                <Layers>
                    <Layer>
                        <!-- TITLE -->
                        <FontString name="$parentTitle" inherits="GameFontNormalLarge" text="Guidelime Vanilla Settings" font="Fonts\FRIZQT__.TTF">
                            <FontHeight>
                                <AbsValue val="20"/>
                            </FontHeight>
                            <Anchors>
                                <Anchor point="TOP">
                                    <Offset x="0" y="-25"/>
                                </Anchor>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>

                <Frames>
                    <!-- SEPARATOR -->
                    <Frame name="$parentSeparator">
                        <Size>
                            <AbsDimension x="600" y="1"/>
                        </Size>
                        <Anchors>
                            <Anchor point="BOTTOM">
                                <Offset x="0" y="-10"/>
                            </Anchor>
                        </Anchors>
                        <Layers>
                            <Layer level="BACKGROUND">
                                <Texture>
                                    <Color r="0.79" g="0.79" b="0.79" a="0.8"/>
                                </Texture>
                            </Layer>
                        </Layers>
                    </Frame>

                    <!-- CLOSE BUTTON -->
                    <Button name="$parentCloseButton" inherits="UIPanelButtonTemplate">
                        <Size>
                            <AbsDimension x="24" y="24"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPRIGHT" RelativeTo="GLV_Settings" RelativePoint="TOPRIGHT">
                                <Offset x="-10" y="-10"/>
                            </Anchor>
                        </Anchors>
                        <NormalTexture file="Interface\Buttons\UI-Panel-MinimizeButton-Up"/>
                        <PushedTexture file="Interface\Buttons\UI-Panel-MinimizeButton-Down"/>
                        <HighlightTexture file="Interface\Buttons\UI-Panel-MinimizeButton-Highlight" alphaMode="ADD"/>
                        <Scripts>
                            <OnClick>
                                GLV_Settings:Hide();
                            </OnClick>
                        </Scripts>
                    </Button>
                </Frames>

            </Frame>
            <!-- END HEADER -->
            
            <!-- LEFT MENU -->
            <Frame name="$parentMenu" inherits="UIPanelFrameTemplate">
                <Size>
                    <AbsDimension x="140" y="500"/>
                </Size>
                <Anchors>
                    <Anchor point="TOPLEFT" RelativeTo="GLV_SettingsHeader" RelativePoint="BOTTOMLEFT">
                        <Offset x="15" y="-60"/>
                    </Anchor>
                </Anchors>

                <Frames>
                    <!-- SEPARATOR -->
                    <Frame name="$parentSeparator">
                        <Size>
                            <AbsDimension x="1" y="500"/>
                        </Size>
                        <Anchors>
                            <Anchor point="RIGHT">
                                <Offset x="0" y="0"/>
                            </Anchor>
                        </Anchors>
                        <Layers>
                            <Layer level="BACKGROUND">
                                <Texture>
                                    <Color r="0.49" g="0.49" b="0.49" a="0.8"/>
                                </Texture>
                            </Layer>
                        </Layers>
                    </Frame>

                    <!-- GUIDE BUTTON -->
                    <Frame name="$parentGuides" inherits="">
                        <Size>
                            <AbsDimension x="140" y="30"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT">
                                <Offset x="0" y="0"/>
                            </Anchor>
                        </Anchors>
                        <Layers>
                            <Layer>
                                <FontString name="$parentText" inherits="GameFontNormalLarge" text="Guides"/>
                            </Layer>
                        </Layers>
                        <Scripts>
                            <OnMouseDown>
                                GLV_ShowGuide(GLV_SettingsGuidesPage)
                            </OnMouseDown>
                            <OnEnter>
                                getglobal(this:GetName().."Text"):SetTextColor(1, 1, 1)
                            </OnEnter>
                            <OnLeave>
                                getglobal(this:GetName().."Text"):SetTextColor(1, 0.82, 0)
                            </OnLeave>
                        </Scripts>
                    </Frame>

                    <!-- DISPLAY BUTTON -->
                    <Frame name="$parentDisplay" inherits="">
                        <Size>
                            <AbsDimension x="140" y="30"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT" RelativeTo="GLV_SettingsMenuGuides" RelativePoint="BOTTOMLEFT"/>
                        </Anchors>
                        <Layers>
                            <Layer>
                                <FontString name="$parentText" inherits="GameFontNormalLarge" text="Display"/>
                            </Layer>
                        </Layers>
                        <Scripts>
                            <OnMouseDown>
                                GLV_ShowGuide(GLV_SettingsDisplayPage)
                            </OnMouseDown>
                            <OnEnter>
                                getglobal(this:GetName().."Text"):SetTextColor(1, 1, 1)
                            </OnEnter>
                            <OnLeave>
                                getglobal(this:GetName().."Text"):SetTextColor(1, 0.82, 0)
                            </OnLeave>
                        </Scripts>
                    </Frame>


                    <!-- ABOUT BUTTON -->
                    <Frame name="$parentAbout" inherits="">
                        <Size>
                            <AbsDimension x="140" y="30"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT" RelativeTo="GLV_SettingsMenuDisplay" RelativePoint="BOTTOMLEFT"/>
                        </Anchors>
                        <Layers>
                            <Layer>
                                <FontString name="$parentText" inherits="GameFontNormalLarge" text="About"/>
                            </Layer>
                        </Layers>
                        <Scripts>
                            <OnMouseDown>
                                GLV_ShowGuide(GLV_SettingsAboutPage)
                            </OnMouseDown>
                            <OnEnter>
                                getglobal(this:GetName().."Text"):SetTextColor(1, 1, 1)
                            </OnEnter>
                            <OnLeave>
                                getglobal(this:GetName().."Text"):SetTextColor(1, 0.82, 0)
                            </OnLeave>
                        </Scripts>
                    </Frame>

                </Frames>

            </Frame>
            <!-- END MENU -->

            <!-- PAGES -->
            <Frame>
                <Size>
                    <AbsDimension x="700" y="500"/>
                </Size>
                <Anchors>
                    <Anchor point="TOPRIGHT" RelativeTo="GLV_SettingsHeader" RelativePoint="BOTTOMRIGHT">
                        <Offset x="-25" y="-60"/>
                    </Anchor>
                </Anchors>

                <Frames>

                    <Frame name="$parentGuidesPage" hidden="false">

                        <Size>
                            <AbsDimension x="700" y="500"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT">
                                <Offset x="0" y="0"/>
                            </Anchor>
                        </Anchors>

                        <Layers>
                            <Layer>
                                <FontString name="$parentTitle" inherits="GameFontNormalLarge" text="Guides" font="Fonts\FRIZQT__.TTF">
                                    <Anchors>
                                        <Anchor point="TOP" RelativeTo="$parent" RelativePoint="TOP"/>
                                    </Anchors>
                                    <FontHeight>
                                        <AbsValue val="20"/>
                                    </FontHeight>
                                </FontString>
                                <!-- Guide Pack Section Title -->
                                <FontString name="$parentGuidePackTitle" inherits="GameFontNormal" text="Guide Pack">
                                    <Anchors>
                                        <Anchor point="TOPLEFT" RelativeTo="$parent" RelativePoint="TOPLEFT">
                                            <Offset x="20" y="-50"/>
                                        </Anchor>
                                    </Anchors>
                                    <Color r="1" g="0.82" b="0"/>
                                </FontString>
                                <!-- Automation Section Title -->
                                <FontString name="$parentAutomationTitle" inherits="GameFontNormal" text="Automation">
                                    <Anchors>
                                        <Anchor point="TOPLEFT" RelativeTo="$parent" RelativePoint="TOPLEFT">
                                            <Offset x="20" y="-150"/>
                                        </Anchor>
                                    </Anchors>
                                    <Color r="1" g="0.82" b="0"/>
                                </FontString>
                            </Layer>
                        </Layers>

                        <Frames>
                            <!-- Guide Pack Dropdown -->
                            <Frame name="$parentGuidePackDropdown" inherits="UIDropDownMenuTemplate">
                                <Anchors>
                                    <Anchor point="TOPLEFT" RelativeTo="GLV_SettingsGuidesPageGuidePackTitle" RelativePoint="BOTTOMLEFT">
                                        <Offset x="-15" y="-5"/>
                                    </Anchor>
                                </Anchors>
                                <Scripts>
                                    <OnLoad>
                                        UIDropDownMenu_SetWidth(200, this);
                                    </OnLoad>
                                    <OnShow>
                                        GLV_InitGuidePackDropdown(this);
                                    </OnShow>
                                </Scripts>
                            </Frame>

                            <!-- Load Button -->
                            <Button name="$parentLoadPackButton" inherits="UIPanelButtonTemplate">
                                <Size>
                                    <AbsDimension x="80" y="22"/>
                                </Size>
                                <Anchors>
                                    <Anchor point="LEFT" RelativeTo="GLV_SettingsGuidesPageGuidePackDropdown" RelativePoint="RIGHT">
                                        <Offset x="-10" y="2"/>
                                    </Anchor>
                                </Anchors>
                                <Scripts>
                                    <OnLoad>
                                        this:SetText("Load");
                                    </OnLoad>
                                    <OnClick>
                                        GLV_LoadSelectedGuidePack();
                                    </OnClick>
                                </Scripts>
                            </Button>

                            <!-- Guide Pack Notes -->
                            <Frame name="$parentGuidePackNotes">
                                <Size>
                                    <AbsDimension x="400" y="40"/>
                                </Size>
                                <Anchors>
                                    <Anchor point="TOPLEFT" RelativeTo="GLV_SettingsGuidesPageGuidePackDropdown" RelativePoint="BOTTOMLEFT">
                                        <Offset x="20" y="-10"/>
                                    </Anchor>
                                </Anchors>
                                <Layers>
                                    <Layer>
                                        <FontString name="$parentText" inherits="GameFontNormalSmall">
                                            <Anchors>
                                                <Anchor point="TOPLEFT"/>
                                            </Anchors>
                                            <Color r="0.8" g="0.8" b="0.8"/>
                                        </FontString>
                                    </Layer>
                                </Layers>
                            </Frame>

                            <!-- Separator between Guide Pack and Automation -->
                            <Frame name="$parentSeparator">
                                <Size>
                                    <AbsDimension x="300" y="1"/>
                                </Size>
                                <Anchors>
                                    <Anchor point="BOTTOMLEFT" RelativeTo="GLV_SettingsGuidesPageAutomationTitle" RelativePoint="TOPLEFT">
                                        <Offset x="0" y="7"/>
                                    </Anchor>
                                </Anchors>
                                <Layers>
                                    <Layer level="BACKGROUND">
                                        <Texture>
                                            <Color r="0.5" g="0.5" b="0.5" a="0.8"/>
                                        </Texture>
                                    </Layer>
                                </Layers>
                            </Frame>

                            <!-- Auto Accept Quests Checkbox -->
                            <CheckButton name="$parentAutoAcceptQuests" inherits="OptionsCheckButtonTemplate">
                                <Anchors>
                                    <Anchor point="TOPLEFT" RelativeTo="GLV_SettingsGuidesPageAutomationTitle" RelativePoint="BOTTOMLEFT">
                                        <Offset x="0" y="-5"/>
                                    </Anchor>
                                </Anchors>
                                <Scripts>
                                    <OnLoad>
                                        getglobal(this:GetName().."Text"):SetText("Auto Accept Quests (beta)");
                                    </OnLoad>
                                    <OnShow>
                                        GLV_InitAutomationCheckbox(this, {"Automation", "AutoAcceptQuests"});
                                    </OnShow>
                                    <OnClick>
                                        GLV_OnAutomationCheckboxClick(this, {"Automation", "AutoAcceptQuests"});
                                    </OnClick>
                                </Scripts>
                            </CheckButton>

                            <!-- Auto Turnin Quests Checkbox -->
                            <CheckButton name="$parentAutoTurninQuests" inherits="OptionsCheckButtonTemplate">
                                <Anchors>
                                    <Anchor point="TOPLEFT" RelativeTo="GLV_SettingsGuidesPageAutoAcceptQuests" RelativePoint="BOTTOMLEFT">
                                        <Offset x="0" y="-5"/>
                                    </Anchor>
                                </Anchors>
                                <Scripts>
                                    <OnLoad>
                                        getglobal(this:GetName().."Text"):SetText("Auto Turnin Quests (beta)");
                                    </OnLoad>
                                    <OnShow>
                                        GLV_InitAutomationCheckbox(this, {"Automation", "AutoTurninQuests"});
                                    </OnShow>
                                    <OnClick>
                                        GLV_OnAutomationCheckboxClick(this, {"Automation", "AutoTurninQuests"});
                                    </OnClick>
                                </Scripts>
                            </CheckButton>

                            <!-- Auto Take Flight Checkbox -->
                            <CheckButton name="$parentAutoTakeFlight" inherits="OptionsCheckButtonTemplate">
                                <Anchors>
                                    <Anchor point="TOPLEFT" RelativeTo="GLV_SettingsGuidesPageAutoTurninQuests" RelativePoint="BOTTOMLEFT">
                                        <Offset x="0" y="-5"/>
                                    </Anchor>
                                </Anchors>
                                <Scripts>
                                    <OnLoad>
                                        getglobal(this:GetName().."Text"):SetText("Auto Take Flights (beta)");
                                    </OnLoad>
                                    <OnShow>
                                        GLV_InitAutomationCheckbox(this, {"Automation", "AutoTakeFlight"});
                                    </OnShow>
                                    <OnClick>
                                        GLV_OnAutomationCheckboxClick(this, {"Automation", "AutoTakeFlight"});
                                    </OnClick>
                                </Scripts>
                            </CheckButton>

                            <!-- Unload Guide Button -->
                            <Button name="$parentUnloadGuideButton" inherits="UIPanelButtonTemplate">
                                <Size>
                                    <AbsDimension x="140" y="22"/>
                                </Size>
                                <Anchors>
                                    <Anchor point="BOTTOMLEFT" RelativeTo="GLV_SettingsGuidesPage" RelativePoint="BOTTOMLEFT">
                                        <Offset x="20" y="20"/>
                                    </Anchor>
                                </Anchors>
                                <Scripts>
                                    <OnLoad>
                                        this:SetText("Unload current guide");
                                    </OnLoad>
                                    <OnClick>
                                        GLV_UnloadCurrentGuide();
                                    </OnClick>
                                </Scripts>
                            </Button>
                        </Frames>

                    </Frame>

                    <Frame name="$parentDisplayPage" hidden="true">

                        <Size>
                            <AbsDimension x="700" y="500"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT">
                                <Offset x="0" y="0"/>
                            </Anchor>
                        </Anchors>

                        <Layers>
                            <Layer>
                                <FontString name="$parentTitle" inherits="GameFontNormalLarge" text="Display settings" font="Fonts\FRIZQT__.TTF">
                                    <Anchors>
                                        <Anchor point="TOP" RelativeTo="$parent" RelativePoint="TOP"/>
                                    </Anchors>
                                    <FontHeight>
                                        <AbsValue val="20"/>
                                    </FontHeight>
                                </FontString>
                                <!-- Guide Text Scale Section -->
                                <FontString name="$parentGuideScaleTitle" inherits="GameFontNormal" text="Guide Text Scale">
                                    <Anchors>
                                        <Anchor point="TOPLEFT" RelativeTo="$parent" RelativePoint="TOPLEFT">
                                            <Offset x="20" y="-50"/>
                                        </Anchor>
                                    </Anchors>
                                    <Color r="1" g="0.82" b="0"/>
                                </FontString>
                                <!-- Navigation Scale Section -->
                                <FontString name="$parentNavScaleTitle" inherits="GameFontNormal" text="Navigation Scale">
                                    <Anchors>
                                        <Anchor point="TOPLEFT" RelativeTo="$parent" RelativePoint="TOPLEFT">
                                            <Offset x="20" y="-140"/>
                                        </Anchor>
                                    </Anchors>
                                    <Color r="1" g="0.82" b="0"/>
                                </FontString>
                            </Layer>
                        </Layers>

                        <Frames>
                            <!-- Guide Text Scale Slider -->
                            <Slider name="$parentGuideScaleSlider" inherits="OptionsSliderTemplate">
                                <Size>
                                    <AbsDimension x="200" y="17"/>
                                </Size>
                                <Anchors>
                                    <Anchor point="TOPLEFT" RelativeTo="GLV_SettingsDisplayPageGuideScaleTitle" RelativePoint="BOTTOMLEFT">
                                        <Offset x="10" y="-15"/>
                                    </Anchor>
                                </Anchors>
                                <Scripts>
                                    <OnLoad>
                                        getglobal(this:GetName().."Low"):SetText("0.8");
                                        getglobal(this:GetName().."High"):SetText("1.5");
                                        getglobal(this:GetName().."Text"):SetText("1.0");
                                        this:SetMinMaxValues(0.8, 1.5);
                                        this:SetValueStep(0.1);
                                    </OnLoad>
                                    <OnShow>
                                        GLV_InitScaleSlider(this, {"UI", "GuideTextScale"});
                                    </OnShow>
                                    <OnValueChanged>
                                        GLV_OnGuideScaleSliderChanged(this, {"UI", "GuideTextScale"});
                                    </OnValueChanged>
                                </Scripts>
                            </Slider>

                            <!-- Navigation Scale Slider -->
                            <Slider name="$parentNavScaleSlider" inherits="OptionsSliderTemplate">
                                <Size>
                                    <AbsDimension x="200" y="17"/>
                                </Size>
                                <Anchors>
                                    <Anchor point="TOPLEFT" RelativeTo="GLV_SettingsDisplayPageNavScaleTitle" RelativePoint="BOTTOMLEFT">
                                        <Offset x="10" y="-15"/>
                                    </Anchor>
                                </Anchors>
                                <Scripts>
                                    <OnLoad>
                                        getglobal(this:GetName().."Low"):SetText("0.8");
                                        getglobal(this:GetName().."High"):SetText("1.5");
                                        getglobal(this:GetName().."Text"):SetText("1.0");
                                        this:SetMinMaxValues(0.8, 1.5);
                                        this:SetValueStep(0.1);
                                    </OnLoad>
                                    <OnShow>
                                        GLV_InitScaleSlider(this, {"UI", "NavigationScale"});
                                    </OnShow>
                                    <OnValueChanged>
                                        GLV_OnNavScaleSliderChanged(this, {"UI", "NavigationScale"});
                                    </OnValueChanged>
                                </Scripts>
                            </Slider>
                        </Frames>

                    </Frame>

                    <Frame name="$parentAboutPage" hidden="true">

                         <Size>
                            <AbsDimension x="700" y="500"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT">
                                <Offset x="0" y="0"/>
                            </Anchor>
                        </Anchors>

                        <Layers>
                            <Layer>
                                <FontString name="$parentTitle" inherits="GameFontNormalLarge" text="About the addon" font="Fonts\FRIZQT__.TTF">
                                    <Anchors>
                                        <Anchor point="TOP" RelativeTo="$parent" RelativePoint="TOP"/>
                                    </Anchors>
                                    <FontHeight>
                                        <AbsValue val="20"/>
                                    </FontHeight>
                                </FontString>
                                <FontString name="$parentContent" inherits="GameFontNormal">
                                    <Anchors>
                                        <Anchor point="TOPLEFT" RelativeTo="$parent" RelativePoint="TOPLEFT">
                                            <Offset x="0" y="-40"/>
                                        </Anchor>
                                    </Anchors>
                                </FontString>
                            </Layer>
                        </Layers>

                        <Frames>
                            <Button name="$parentLinkOriginal">
                                <Size>
                                    <AbsDimension x="300" y="20"/>
                                </Size>
                                <Anchors>
                                    <Anchor point="TOPLEFT" RelativeTo="GLV_SettingsAboutPageContent">
                                        <Offset x="204" y="-200"/>
                                    </Anchor>
                                </Anchors>
                                <Layers>
                                    <Layer>
                                        <FontString name="$parentText" inherits="GameFontNormal" text="https://code.google.com/archive/p/vanillaguide/">
                                            <Color r="1" g="1" b="1"/>
                                        </FontString>
                                    </Layer>
                                </Layers>
                                <Scripts>
                                    <OnClick>
                                        if ChatFrameEditBox then
                                            ChatFrameEditBox:SetText("https://code.google.com/archive/p/vanillaguide/");
                                            ChatFrameEditBox:Show();
                                            ChatFrameEditBox:HighlightText();
                                        end
                                    </OnClick>
                                    <OnEnter>
                                        getglobal(this:GetName().."Text"):SetTextColor(0.2, 0.6, 1);
                                    </OnEnter>
                                    <OnLeave>
                                        getglobal(this:GetName().."Text"):SetTextColor(1, 1, 1);
                                    </OnLeave>
                                </Scripts>
                            </Button>
                            <Button name="$parentLinkGithub">
                                <Size>
                                    <AbsDimension x="300" y="20"/>
                                </Size>
                                <Anchors>
                                    <Anchor point="TOPLEFT" RelativeTo="GLV_SettingsAboutPageContent">
                                        <Offset x="335" y="-224"/>
                                    </Anchor>
                                </Anchors>
                                <Layers>
                                    <Layer>
                                        <FontString name="$parentText" inherits="GameFontNormal" text="https://github.com/JeromeM/VanillaGuideReloaded">
                                            <Color r="1" g="1" b="1"/>
                                        </FontString>
                                    </Layer>
                                </Layers>
                                <Scripts>
                                    <OnClick>
                                        if ChatFrameEditBox then
                                            ChatFrameEditBox:SetText("https://github.com/JeromeM/VanillaGuideReloaded");
                                            ChatFrameEditBox:Show();
                                            ChatFrameEditBox:HighlightText();
                                        end
                                    </OnClick>
                                    <OnEnter>
                                        getglobal(this:GetName().."Text"):SetTextColor(0.2, 0.6, 1);
                                    </OnEnter>
                                    <OnLeave>
                                        getglobal(this:GetName().."Text"):SetTextColor(1, 1, 1);
                                    </OnLeave>
                                </Scripts>
                            </Button>
                        </Frames>

                        <Scripts>
                            <OnShow>GLV_SettingsAboutPage_OnLoad()</OnShow>
                        </Scripts>

                    </Frame>

                </Frames>

            </Frame>
           
        </Frames>
        
    </Frame>

</Ui>
