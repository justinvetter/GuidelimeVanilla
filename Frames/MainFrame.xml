<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <Frame name="GLV_Main" parent="UIParent" toplevel="true" movable="true" resizable="false" frameStrata="DIALOG" enableMouse="true" hidden="false">

        <Size>
            <AbsDimension x="450" y="400"/>
        </Size>
        <Anchors>
            <Anchor point="CENTER"/>
        </Anchors>

        <Backdrop bgFile="Interface\DialogFrame\UI-DialogBox-Background" edgeFile="Interface\DialogFrame\UI-DialogBox-Border" tile="true">
            <EdgeSize>
                <AbsValue val="16"/>
            </EdgeSize>
            <TileSize>
                <AbsValue val="32"/>
            </TileSize>
            <BackgroundInsets>
                <AbsInset left="5" right="5" top="5" bottom="5"/>
            </BackgroundInsets>
        </Backdrop>

        <Scripts>
            <OnLoad>
                this:RegisterForDrag("LeftButton");
            </OnLoad>
            <OnDragStart>
                this:StartMoving();
            </OnDragStart>
            <OnDragStop>
                this:StopMovingOrSizing();
            </OnDragStop>
        </Scripts>        

        <Layers>
            <Layer level="OVERLAY">
                <FontString name="$parentTitle" inherits="GameFontNormal">
                    <Anchors>
                        <Anchor point="TOP">
                            <Offset x="0" y="-14"/>
                        </Anchor>
                    </Anchors>
                    <Color r="0.396" g="0.42" b="0.737"/>
                     <Shadow>
                        <Offset>
                            <AbsDimension x="2" y="2" />
                        </Offset>
                        <Color r="0" g="0" b="0" />
                    </Shadow>
                </FontString>
            </Layer>
        </Layers>

        <Frames>

            <Button name="$parentClose" inherits="UIPanelButtonTemplate">
                <Size>
                    <AbsDimension x="24" y="24"/>
                </Size>
                <Anchors>
                    <Anchor point="TOPRIGHT">
                        <Offset x="-10" y="-8"/>
                    </Anchor>
                </Anchors>
                <NormalTexture file="Interface\Buttons\UI-Panel-MinimizeButton-Up"/>
                <PushedTexture file="Interface\Buttons\UI-Panel-MinimizeButton-Down"/>
                <Scripts>
                    <OnClick>GLV_NextPrevStep(true)</OnClick>
                </Scripts>
            </Button>

            <Frame name="$parentLoadedGuide" hidden="false">

                <Size>
                    <AbsDimension x="400" y="30"/>
                </Size>
                <Anchors>
                    <Anchor point="TOP" RelativeTo="$parentTitle" RelativePoint="BOTTOM">
                        <Offset x="-10" y="-5"/>
                    </Anchor>
                </Anchors>

                <Frames>
                    <Frame name="$parentClassIcon">
                        <Size>
                            <AbsDimension x="20" y="20"/>
                        </Size>
                    </Frame>
                </Frames>

                <Layers>
                    <Layer>
                        <FontString name="$parentTitle" inherits="GameFontNormalSmall" font="Fonts\FRIZQT__.TTF" JustifyV="MIDDLE" JustifyH="LEFT">
                            <FontHeight>
                                <AbsValue val="12"/>
                            </FontHeight>
                        </FontString>
                    </Layer>
                    <Layer>
                        <FontString name="$parentCounter" inherits="GameFontNormalSmall" font="Fonts\FRIZQT__.TTF" JustifyV="MIDDLE" JustifyH="RIGHT">
                            <FontHeight>
                                <AbsValue val="12"/>
                            </FontHeight>
                        </FontString>
                    </Layer>
                </Layers>

            </Frame>

            <ScrollFrame name="$parentScrollFrame" inherits="UIPanelScrollFrameTemplate">
                <Size>
                    <AbsDimension x="400" y="285"/>
                </Size>
                <Anchors>
                    <Anchor point="TOPLEFT">
                        <Offset x="15" y="-65"/>
                    </Anchor>
                </Anchors>

                <ScrollChild>
                    <Frame name="$parentScrollChild">
                        <Size>
                            <AbsDimension x="300" y="1"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT"/>
                        </Anchors>
                    </Frame>
                </ScrollChild>
            </ScrollFrame>

            <Frame name="$parentDropdown" inherits="UIDropDownMenuTemplate">
                <Anchors>
                    <Anchor point="BOTTOMLEFT">
                        <Offset x="0" y="7"/>
                    </Anchor>
                </Anchors>
                <Scripts>
                    <OnLoad>
                        UIDropDownMenu_SetWidth(200, GLV_MainDropdown)
                        UIDropDownMenu_SetButtonWidth(200, GLV_MainDropdown)
                    </OnLoad>
                </Scripts>
            </Frame>

            <Button name="$parentSettings" inherits="UIPanelButtonTemplate">
                <Size>
                    <AbsDimension x="16" y="16"/>
                </Size>
                <Anchors>
                    <Anchor point="BOTTOMRIGHT">
                        <Offset x="-15" y="17"/>
                    </Anchor>
                </Anchors>
                <NormalTexture file="Interface\AddOns\GuideLimeVanilla\Textures\Settings"/>
                <PushedTexture file="Interface\AddOns\GuideLimeVanilla\Textures\Settings"/>
                <Scripts>
                    <OnClick>GLV_ToggleSettings()</OnClick>
                </Scripts>
            </Button>

        </Frames>

    </Frame>

</Ui>
